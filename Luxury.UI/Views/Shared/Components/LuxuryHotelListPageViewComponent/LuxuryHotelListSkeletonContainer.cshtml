@model ResultHotelDto
<div class="results-header my-4">
    <div class="results-count">
        <i class="bi bi-sliders me-2 gold-text"></i>
        <span>@Model.WishlistName Bölgesindeki En Seçkin Tesisler (@(ViewBag.Count ?? 0) Otel Listeleniyor)</span>
    </div>
</div>

<div id="skeletonContainer">
    @for (int i = 0; i < 3; i++)
    {
        <div class="skeleton-card mb-4">
            <div class="row g-0">
                <div class="col-md-4 skeleton-pulse bg-skeleton-img"></div>
                <div class="col-md-8 p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="skeleton-pulse mb-3" style="height: 28px; width: 60%; border-radius:4px;"></div>
                        <div class="skeleton-pulse mb-2" style="height: 20px; width: 30%; border-radius:4px;"></div>
                        <div class="skeleton-pulse mb-2" style="height: 16px; width: 80%; border-radius:4px;"></div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <div class="skeleton-pulse" style="height: 24px; width: 25%; border-radius:4px;"></div>
                        <div class="skeleton-pulse" style="height: 45px; width: 30%; border-radius:4px;"></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>