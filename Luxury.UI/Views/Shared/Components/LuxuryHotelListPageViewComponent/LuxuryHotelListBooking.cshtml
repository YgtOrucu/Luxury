@model ResultHotelDto

<section class="booking-section" id="booking-form" aria-label="Otel Arama Formu">
    <div class="container-xl">
        <div class="booking-wrapper glass-panel compact-search-bar animate-fade-in">
            <form class="booking-form"
                  action="/Hotel/Search"
                  method="get"
                  id="hotelSearchForm"
                  role="search"
                  aria-label="Otel arama formu">

                <div class="row g-3 align-items-end">

                    <div class="col-12 col-md-6 col-lg-3">
                        <div class="form-group-luxury">
                            <label for="city" class="form-label-luxury">
                                <i class="bi bi-geo-alt" aria-hidden="true"></i> Şehir / Destinasyon
                            </label>
                            <input type="text"
                                   class="form-control-luxury"
                                   id="city"
                                   name="City"
                                   value="@(Model.WishlistName ?? "Dubai")"
                                   placeholder="Paris, Roma, Dubai..."
                                   autocomplete="off"
                                   required
                                   aria-required="true"
                                   aria-label="Şehir veya destinasyon giriniz" />
                        </div>
                    </div>

                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="form-group-luxury">
                            <label for="checkIn" class="form-label-luxury">
                                <i class="bi bi-calendar3" aria-hidden="true"></i> Giriş Tarihi
                            </label>
                            <input type="date"
                                   class="form-control-luxury"
                                   id="checkIn"
                                   name="CheckIn"
                                   value="@(Model?.CheckinDate ?? DateTime.Now.ToString("yyyy-MM-dd"))"
                                   required
                                   aria-required="true"
                                   aria-label="Giriş tarihi" />
                        </div>
                    </div>

                    <div class="col-6 col-md-3 col-lg-2">
                        <div class="form-group-luxury">
                            <label for="checkOut" class="form-label-luxury">
                                <i class="bi bi-calendar3-fill" aria-hidden="true"></i> Çıkış Tarihi
                            </label>
                            <input type="date"
                                   class="form-control-luxury"
                                   id="checkOut"
                                   name="CheckOut"
                                   value="@(Model?.CheckoutDate ?? DateTime.Now.AddDays(1).ToString("yyyy-MM-dd"))"
                                   required
                                   aria-required="true"
                                   aria-label="Çıkış tarihi" />
                        </div>
                    </div>

                    <div class="col-4 col-md-4 col-lg-1">
                        <div class="form-group-luxury">
                            <label for="adults" class="form-label-luxury">
                                <i class="bi bi-person" aria-hidden="true"></i> Yetişkin
                            </label>
                            <select class="form-control-luxury" id="adults" name="Adults" aria-label="Yetişkin sayısı">
                                @{
                                    int selectedAdults = ViewBag.Adults ?? 1;
                                    for (int i = 1; i <= 6; i++)
                                    {
                                        <option value="@i" selected="@(selectedAdults == i ? "selected" : null)">@i</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-4 col-md-4 col-lg-1">
                        <div class="form-group-luxury">
                            <label for="children" class="form-label-luxury">
                                <i class="bi bi-person-heart" aria-hidden="true"></i> Çocuk
                            </label>
                            <select class="form-control-luxury" id="children" name="Children" aria-label="Çocuk sayısı">
                                @{
                                    int selectedChildren = ViewBag.Rooms ?? 0;
                                    for (int i = 0; i <= 4; i++)
                                    {
                                        <option value="@i" selected="@(selectedChildren == i ? "selected" : null)">@i</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-4 col-md-4 col-lg-1">
                        <div class="form-group-luxury">
                            <label for="rooms" class="form-label-luxury">
                                <i class="bi bi-door-open" aria-hidden="true"></i> Oda
                            </label>
                            <select class="form-control-luxury" id="rooms" name="Rooms" aria-label="Oda sayısı">
                                @{
                                    int selectedRooms = ViewBag.Rooms ?? 1;
                                    for (int i = 1; i <= 4; i++)
                                    {
                                        <option value="@i" selected="@(selectedRooms == i ? "selected" : null)">@i</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="col-12 col-lg-2">
                        <button type="submit" class="btn-search-luxury w-100" aria-label="Otel ara">
                            <i class="bi bi-search" aria-hidden="true"></i>
                            <span>Ara</span>
                        </button>
                    </div>

                </div>

                <div class="form-error-msg" id="formError" role="alert" aria-live="polite" hidden>
                    Lütfen tüm zorunlu alanları doldurun.
                </div>
            </form>
        </div>
    </div>
</section>