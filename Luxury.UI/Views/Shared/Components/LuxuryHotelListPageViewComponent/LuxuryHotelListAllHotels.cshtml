@model List<ResultHotelDto>

<div id="realHotelsContainer" class="d-none-custom">
    @if (Model != null && Model.Any())
    {
        @foreach (var hotel in Model)
        {
            <div class="card hotel-card p-0 mb-4">
                <div class="row g-0">
                    <div class="col-md-4 img-container">
                        <img src="@hotel.MainPhotoUrl" class="hotel-img" alt="@hotel.Name" loading="lazy">
                        <div class="img-overlay-glow"></div>
                    </div>
                    <div class="col-md-8">
                        <div class="card-content-wrap h-100 d-flex flex-column justify-content-between p-4">
                            <div class="row">
                                <div class="col-sm-8">
                                    <h3 class="hotel-title">@hotel.Name</h3>

                                    <div class="mb-2 d-flex align-items-center gap-2">
                                        <span class="rating-badge">
                                            <i class="bi bi-star-fill gold-text me-1"></i>
                                            <strong>@hotel.ReviewScore</strong> / 10
                                        </span>
                                        <span class="review-word gold-text-muted">@hotel.ReviewScoreWord</span>
                                    </div>

                                    <div class="hotel-stars mb-3">
                                        @for (int i = 0; i < hotel.PropertyClass; i++)
                                        {
                                            <i class="bi bi-star-fill text-warning me-1 small-star"></i>
                                        }
                                        <span class="property-class-text">(@hotel.PropertyClass Yıldızlı Tesis)</span>
                                    </div>

                                    <ul class="hotel-features-list">
                                        <li><i class="bi bi-chat-left-text gold-text"></i> <span>@hotel.ReviewCount Değerlendirme</span></li>
                                        <li><i class="bi bi-geo-alt gold-text"></i> <span>Mükemmel Konum</span></li>
                                        <li><i class="bi bi-shield-check gold-text"></i> <span>Ücretsiz İptal Seçeneği</span></li>
                                    </ul>
                                </div>

                                <div class="col-sm-4 d-flex flex-column justify-content-between align-items-sm-end mt-3 mt-sm-0 text-sm-end">
                                    <div class="price-section">
                                        <span class="price-lbl">TOPLAM TUTAR</span>
                                        <span class="price-amount">@hotel.AmountRounded</span>
                                    </div>
                                    <form action="/Hotel/Details" method="get">
                                        <input type="hidden" name="id" value="@hotel.Id" />

                                        <input type="hidden" name="checkInDate" value="@hotel.CheckinDate" />
                                        <input type="hidden" name="checkOutDate" value="@hotel.CheckoutDate" />
                                        <input type="hidden" name="rooms" value="@ViewBag.Rooms" />
                                        <input type="hidden" name="adults" value="@ViewBag.Adults" />
                                        <input type="hidden" name="children" value="@ViewBag.Children" />
                                        <input type="hidden" name="units" value="@hotel.Units" />
                                        <input type="hidden" name="currencyCode" value="@hotel.CurrencyCode" />
                                        <input type="hidden" name="language" value="@hotel.Language" />

                                        <button type="submit" class="btn-luxury mt-3 w-100 text-center">
                                            <span>Detayları İncele</span>
                                            <i class="bi bi-arrow-right ms-2"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="card hotel-card p-5 text-center border-luxury-dim">
            <div class="py-4">
                <i class="bi bi-exclamation-circle text-warning fs-1 mb-3 d-block"></i>
                <h4 class="font-playfair text-white mb-2" style="letter-spacing: 1px;">Hiçbir Seçkin Tesis Bulunamadı</h4>
                <p class="text-white-50 small mx-auto" style="max-width: 450px;">
                    Belirttiğiniz tarihlerde veya destinasyonda kriterlerinize uygun lüks konaklama seçeneği mevcut değil. Lütfen tarihlerinizi güncelleyerek yeniden aramayı deneyin.
                </p>
            </div>
        </div>
    }
</div>