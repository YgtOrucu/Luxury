@model HotelDetailDto
@{
    Layout = null;
    var hasRooms = Model?.rooms != null && Model.rooms.Count > 0;
    var hasFacilities = Model?.facilities_block?.facilities != null && Model.facilities_block.facilities.Length > 0;
    var hasTopBenefits = Model?.top_ufi_benefits != null && Model.top_ufi_benefits.Length > 0;
    var hasFamilyFacilities = Model?.family_facilities != null && Model.family_facilities.Length > 0;
    var hasChains = Model?.chains != null && Model.chains.Length > 0;
    var hasPrice = Model?.composite_price_breakdown != null;
    var totalAdults = Model?.room_recommendation?.Sum(x => x.adults) ?? 0;
    var totalChildren = Model?.room_recommendation?.Sum(x => x.children) ?? 0;
    var totalBabies = Model?.room_recommendation?.Sum(x => x.babies) ?? 0;

}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(Model?.hotel_name ?? "Hotel Detail") – LUXURY</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="~/css/hoteldetails.css" rel="stylesheet" />

</head>
<body>

    <!-- ═══════════════════════════════════════════════════════════════
     NAVBAR
════════════════════════════════════════════════════════════════ -->
    <nav class="navbar navbar-expand-lg luxury-nav" id="mainNav" role="navigation" aria-label="Main navigation">
        <div class="container-xl">
            <a class="navbar-brand luxury-brand" href="/">
                <span class="brand-icon">✦</span>
                <span class="brand-text">LUXURY</span>
            </a>
            <button class="navbar-toggler border-0 p-0 luxury-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarContent"
                    aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span></span><span></span><span></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto gap-lg-4">
                    <li><a href="/Luxury/Index#market-data">Canlı Veriler</a></li>
                    <li><a href="/Luxury/Index#features">Özellikler</a></li>
                    <li><a href="/Luxury/Index#destinations">Lokasyonlar</a></li>
                </ul>
                <div>
                    <a href="#booking-form" class="btn-primary-nav">Rezervasyon Yap</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- ═══════════════════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════════════════ -->
    <section class="hero-section" aria-label="Hotel hero">
        <!-- Slider images from first room photos -->
        <div class="hero-slider" id="heroSlider">
            @{
                var heroPhotos = new List<string>();
                if (hasRooms)
                {
                    foreach (var room in Model.rooms.Values)
                    {
                        if (room?.photos != null)
                        {
                            foreach (var p in room.photos)
                            {
                                if (!string.IsNullOrEmpty(p?.url_original))
                                    heroPhotos.Add(p.url_original);
                                if (heroPhotos.Count >= 6) break;
                            }
                        }
                        if (heroPhotos.Count >= 6) break;
                    }
                }
            }
            @if (heroPhotos.Any())
            {
                for (int hi = 0; hi < heroPhotos.Count; hi++)
                {
                    <div class="hero-slide @(hi == 0 ? "active" : "")"
                         style="background-image:url('@heroPhotos[hi]')"
                         role="img" aria-label="Hotel image @(hi + 1)"></div>
                }
            }
            else
            {
                <div class="hero-fallback" role="img" aria-label="Hotel background"></div>
            }
        </div>

        <!-- Slider dots -->
        @if (heroPhotos.Count > 1)
        {
            <div class="hero-dots" role="group" aria-label="Slide navigation">
                @for (int di = 0; di < heroPhotos.Count; di++)
                {
                    <button class="hero-dot @(di == 0 ? "active" : "")"
                            data-slide="@di" aria-label="Slide @(di + 1)"></button>
                }
            </div>
        }

        <div class="hero-content">
            <div class="container-xl">
                @if (Model?.is_preferred == 1)
                {
                    <div class="preferred-ribbon">Tercih Edilen</div>
                }
                <div class="hero-eyebrow">
                    @(Model?.country_trans ?? "Luxury Hotel")
                </div>
                <h1 class="hero-title">
                    @{
                        var nameParts = (Model?.hotel_name ?? "Grand Luxury Hotel").Split(' ');
                        var firstWord = nameParts.FirstOrDefault() ?? "";
                        var rest = string.Join(" ", nameParts.Skip(1));
                    }
                    <em>@firstWord</em> @rest
                </h1>
                <p class="hero-location">
                    <i class="bi bi-geo-alt-fill"></i>
                    @(Model?.hotel_address_line ?? Model?.address ?? $"{Model?.city}, {Model?.country_trans}")
                </p>
                <div class="hero-badges">
                    @if (Model?.review_nr > 0)
                    {
                        <span class="hero-badge gold">
                            <i class="bi bi-star-fill me-1"></i>
                            @Model.review_nr.ToString("N0") Değerlendirme
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(Model?.city))
                    {
                        <span class="hero-badge">@Model.city</span>
                    }
                    @if (hasChains)
                    {
                        <span class="hero-badge">@Model.chains[0].name</span>
                    }
                    @if (hasTopBenefits && Model.top_ufi_benefits.Length > 0)
                    {
                        <span class="hero-badge">@Model.top_ufi_benefits[0].translated_name</span>
                    }
                </div>
                <div class="hero-cta-row">
                    <a href="#rooms" class="btn-hero-book" aria-label="Oda seç">
                        <i class="bi bi-calendar-check"></i> Oda Seç
                    </a>
                    <a href="#gallery" class="btn-hero-outline" aria-label="Fotoğrafları gör">
                        <i class="bi bi-images"></i> Galeri
                    </a>
                    @if (hasPrice && !string.IsNullOrEmpty(Model.composite_price_breakdown.gross_amount_per_night.ToString()))
                    {
                        <div class="hero-price-pill ms-auto">
                            <div class="label">Gecelik</div>
                            <div class="amount">
                                @Model.composite_price_breakdown.gross_amount_per_night.amount_rounded
                                <span style="font-size:.9rem;color:var(--accent);">@(Model?.composite_price_breakdown.gross_amount.currency ?? "")</span>
                            </div>
                            <div class="per-night">ortalama fiyat</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
     OVERVIEW + STICKY PRICE
════════════════════════════════════════════════════════════════ -->
    <section class="overview-section" id="overview" aria-label="Hotel overview">
        <div class="container-xl">
            <div class="row g-5">
                <!-- Left col -->
                <div class="col-lg-8 overview-col">

                    <!-- Section heading -->
                    <div class="fade-up">
                        <div class="section-label">Otel Hakkında</div>
                        <h2 class="section-title">
                            <em>Olağanüstü</em> Bir Deneyim
                        </h2>
                        <div class="section-divider"></div>
                    </div>

                    <!-- Top Benefits -->
                    @if (hasTopBenefits)
                    {
                        <div class="fade-up fade-up-d1 mb-4">
                            @foreach (var benefit in Model.top_ufi_benefits)
                            {
                                if (benefit == null) continue;
                                <div class="benefit-item">
                                    <i class="@(!string.IsNullOrEmpty(benefit.icon) ? benefit.icon : "bi bi-check-circle-fill")"></i>
                                    <span>@benefit.translated_name</span>
                                </div>
                            }
                        </div>
                    }

                    <!-- Facilities -->
                    @if (hasFacilities)
                    {
                        <div class="fade-up fade-up-d2 mb-5">
                            <h3 class="section-label mb-3" style="font-size:.7rem;">
                                @(Model.facilities_block.name ?? "Olanaklarımız")
                            </h3>

                            <div class="facilities-grid">
                                @foreach (var fac in Model.facilities_block.facilities)
                                {
                                    if (fac == null) continue;

                                    <div class="facility-item">

                                        @switch (fac.icon?.ToLower())
                                        {
                                            case "nosmoking":
                                                <i class="bi bi-slash-circle"></i>
                                                break;

                                            case "parking_sign":
                                            case "parking":
                                                <i class="bi bi-p-square"></i>
                                                break;

                                            case "disabled":
                                                <i class="bi bi-person-wheelchair"></i>
                                                break;

                                            case "clean":
                                                <i class="bi bi-brush"></i>
                                                break;

                                            case "food_and_drink":
                                            case "restaurant":
                                                <i class="bi bi-cup-hot"></i>
                                                break;

                                            case "family":
                                                <i class="bi bi-people-fill"></i>
                                                break;

                                            case "wifi":
                                                <i class="bi bi-wifi"></i>
                                                break;

                                            case "pawprint":
                                                <i class="bi bi-heart"></i>
                                                break;

                                            default:
                                                <i class="bi bi-check2-circle"></i>
                                                break;
                                        }

                                        <span>@fac.name</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Family Facilities -->
                    @if (hasFamilyFacilities)
                    {
                        <div class="fade-up fade-up-d3 mb-4">
                            <div class="section-label mb-2">Aile Olanakları</div>
                            <div class="family-tags">
                                @foreach (var ff in Model.family_facilities)
                                {
                                    if (string.IsNullOrEmpty(ff)) continue;
                                    <span class="family-tag">
                                        <i class="bi bi-people-fill me-1"></i>@ff
                                    </span>
                                }
                            </div>
                        </div>
                    }

                </div>

                <!-- Right col: Price Box -->
                <div class="col-lg-4" id="booking-form">
                    <div class="price-box fade-up" aria-label="Fiyat bilgisi">
                        <div class="price-box-header">
                            <div class="price-per-night mb-1">Gecelik başlayan fiyatlar</div>
                            @if (hasPrice && !string.IsNullOrEmpty(Model.composite_price_breakdown.gross_amount_per_night.ToString()))
                            {
                                <div class="price-main">
                                    @Model.composite_price_breakdown.gross_amount_per_night.amount_rounded
                                </div>
                            }
                            else
                            {
                                <div class="price-main" style="font-size:1.2rem;color:var(--text-light);">Fiyat sorgulayın</div>
                            }
                            @if (hasPrice && !string.IsNullOrEmpty(Model.composite_price_breakdown.gross_amount.ToString()))
                            {
                                <div class="price-total-row mt-2">
                                    <span>Toplam tutar</span>
                                    <strong>@Model.composite_price_breakdown.gross_amount.amount_rounded</strong>
                                </div>
                            }
                            @if (hasPrice && !string.IsNullOrEmpty(Model.composite_price_breakdown.all_inclusive_amount.ToString()))
                            {
                                <div class="price-total-row">
                                    <span>Her şey dahil</span>
                                    <strong style="color:var(--primary);">@Model.composite_price_breakdown.all_inclusive_amount.amount_rounded</strong>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(Model?.arrival_date) || !string.IsNullOrEmpty(Model?.departure_date))
                        {
                            <div class="price-dates-row">
                                @if (!string.IsNullOrEmpty(Model?.arrival_date))
                                {
                                    <div class="price-date-pill">
                                        <div class="d-label">Giriş</div>
                                        <div class="d-value">@Model.arrival_date</div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(Model?.departure_date))
                                {
                                    <div class="price-date-pill">
                                        <div class="d-label">Çıkış</div>
                                        <div class="d-value">@Model.departure_date</div>
                                    </div>
                                }
                            </div>
                            <div class="price-dates-row">

                                @if (totalAdults > 0)
                                {
                                    <div class="price-date-pill">
                                        <div class="d-label">Yetişkin</div>
                                        <div class="d-value">@totalAdults</div>
                                    </div>
                                }

                                @if (totalChildren > 0)
                                {
                                    <div class="price-date-pill">
                                        <div class="d-label">Çocuk</div>
                                        <div class="d-value">@totalChildren</div>
                                    </div>
                                }

                                @if (totalBabies > 0)
                                {
                                    <div class="price-date-pill">
                                        <div class="d-label">Bebek</div>
                                        <div class="d-value">@totalBabies</div>
                                    </div>
                                }

                            </div>
                        }

                        <a href="#rooms" class="btn-book-now" aria-label="Rezervasyon yap">
                            Rezervasyon Yap
                        </a>

                        <div class="price-badge-row">
                            <span class="price-badge"><i class="bi bi-shield-check me-1"></i>Güvenli ödeme</span>
                            <span class="price-badge"><i class="bi bi-award me-1"></i>En iyi fiyat</span>
                            @if (Model?.review_nr > 0)
                            {
                                <span class="price-badge"><i class="bi bi-star me-1"></i>@Model.review_nr yorum</span>
                            }
                        </div>

                        @if (hasPrice && !string.IsNullOrEmpty(Model.composite_price_breakdown.excluded_amount.ToString()))
                        {
                            <p class="price-policy">
                                <i class="bi bi-info-circle-fill"></i>
                                Hariç tutulan vergiler: <span style="font-weight:bold">@Model.composite_price_breakdown.excluded_amount.amount_rounded </span>
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
     ROOMS
════════════════════════════════════════════════════════════════ -->
    @if (hasRooms)
    {
        <section class="rooms-section" id="rooms" aria-label="Odalar">
            <div class="container-xl">
                <div class="fade-up mb-5">
                    <div class="section-label">Odalar & Süitler</div>
                    <h2 class="section-title">Konforun <em>Zirvesi</em></h2>
                    <div class="section-divider"></div>
                </div>

                <div class="row g-5">
                    @{
                        int roomIdx = 0;
                    }
                    @foreach (var roomKvp in Model.rooms)
                    {
                        var roomKey = roomKvp.Key;
                        var room = roomKvp.Value;
                        if (room == null) continue;
                        var rPhotos = room.photos?.Where(p => p != null && !string.IsNullOrEmpty(p.url_max300)).ToList() ?? new List<PhotoDto>();
                        var hasRoomPhotos = rPhotos.Any();
                        var hasHighlights = room.highlights != null && room.highlights.Length > 0;
                        var hasBeds = room.bed_configurations != null && room.bed_configurations.Length > 0;
                        var hasRoomFacilities = room.facilities != null && room.facilities.Length > 0;
                        var hasChildPolicy = room.children_and_beds_text != null;
                        <div class="col-lg-6 fade-up" style="transition-delay:@(roomIdx * 0.1)s">
                            <article class="room-card" aria-label="@(room.description ?? roomKey)">
                                <!-- Gallery -->
                                <div class="room-gallery" aria-label="Oda fotoğrafları">
                                    @if (Model?.is_preferred == 1)
                                    {
                                        <span class="preferred-ribbon">Tercih Edilen</span>
                                    }
                                    <div class="room-gallery-inner" id="roomGallery_@roomIdx">
                                        @if (hasRoomPhotos)
                                        {
                                            @foreach (var ph in rPhotos)
                                            {
                                                <img src="@ph.url_max300"
                                                     class="room-photo"
                                                     alt="Oda fotoğrafı"
                                                     loading="lazy"
                                                     onerror="this.style.display='none'" />
                                            }
                                        }
                                        else
                                        {
                                            <div style="flex:0 0 100%;height:100%;background:linear-gradient(135deg,#2e2419,#4a3830);display:flex;align-items:center;justify-content:center;">
                                                <i class="bi bi-image" style="font-size:3rem;color:rgba(196,168,130,.3)"></i>
                                            </div>
                                        }
                                    </div>
                                    @if (rPhotos.Count > 1)
                                    {
                                        <button class="room-gallery-nav prev"
                                                onclick="slideRoom('@roomIdx', -1)"
                                                aria-label="Önceki fotoğraf">
                                            <i class="bi bi-chevron-left"></i>
                                        </button>
                                        <button class="room-gallery-nav next"
                                                onclick="slideRoom('@roomIdx', 1)"
                                                aria-label="Sonraki fotoğraf">
                                            <i class="bi bi-chevron-right"></i>
                                        </button>
                                        <span class="room-photo-count" id="roomCount_@roomIdx">1 / @rPhotos.Count</span>
                                    }
                                </div>

                                <!-- Body -->
                                <div class="room-body">
                                    @if (hasBeds)
                                    {
                                        <div class="room-beds">
                                            @foreach (var bc in room.bed_configurations)
                                            {
                                                if (bc?.bed_types == null) continue;
                                                @foreach (var bt in bc.bed_types)
                                                {
                                                    if (bt == null) continue;
                                                    <span class="room-bed-tag">
                                                        <i class="bi bi-moon-stars"></i>
                                                        @bt.name_with_count
                                                    </span>
                                                }
                                            }
                                        </div>
                                    }

                                    @if (hasHighlights)
                                    {
                                        <div class="room-highlights">
                                            @foreach (var hl in room.highlights)
                                            {
                                                if (hl == null) continue;
                                                <span class="room-highlight">@hl.translated_name</span>
                                            }
                                        </div>
                                    }

                                    @if (hasRoomFacilities)
                                    {
                                        <div class="facilities-grid mt-2" style="grid-template-columns:repeat(auto-fill,minmax(200px,1fr));">
                                            @foreach (var rf in room.facilities.Take(10))
                                            {
                                                if (rf == null) continue;
                                                <div class="facility-item" style="font-size:.7rem;">
                                                    <i class="@(!string.IsNullOrEmpty(rf.icon) ? rf.icon : "bi bi-check2")"></i>
                                                    @rf.name
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                                @if (hasChildPolicy)
                                {
                                    <div class="room-policy-accordion">
                                        <button class="room-policy-toggle"
                                                onclick="togglePolicy(this)"
                                                aria-expanded="false">
                                            <i class="bi bi-people"></i> Çocuk & Yatak Politikası
                                            <i class="bi bi-chevron-down ms-auto"></i>
                                        </button>
                                        <div class="room-policy-body">
                                            @if (room.children_and_beds_text.children_at_the_property != null)
                                            {
                                                @foreach (var cp in room.children_and_beds_text.children_at_the_property)
                                                {
                                                    if (cp == null) continue;
                                                    <p>@cp.text</p>
                                                }
                                            }
                                            @if (room.children_and_beds_text.cribs_and_extra_beds != null)
                                            {
                                                @foreach (var cr in room.children_and_beds_text.cribs_and_extra_beds)
                                                {
                                                    if (cr == null) continue;
                                                    <p>@cr.text</p>
                                                }
                                            }
                                        </div>
                                    </div>
                                }

                                <div class="room-policy-accordion">
                                    <button class="room-policy-toggle" onclick="togglePolicy(this)" aria-expanded="false">
                                        <i class="bi bi-people"></i> Oda Açıklaması
                                        <i class="bi bi-chevron-down ms-auto"></i>
                                    </button>
                                    <div class="room-policy-body">
                                        <p>@room.description</p>
                                    </div>
                                </div>

                                <!-- Footer -->
                                <div class="room-footer">
                                    <div>
                                        <div class="room-price-label">Gecelik başlayan</div>
                                        @if (hasPrice && !string.IsNullOrEmpty(Model.composite_price_breakdown.gross_amount_per_night.ToString()))
                                        {
                                            <div class="room-price">
                                                @Model.composite_price_breakdown.gross_amount_per_night.amount_rounded
                                                <span style="font-size:.85rem;color:var(--primary);">@(Model?.composite_price_breakdown.gross_amount_per_night.currency ?? "")</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="room-price" style="font-size:1rem;color:var(--text-light);">Fiyat al</div>
                                        }
                                    </div>
                                    <a href="#booking-form" class="btn-room-select" aria-label="Bu odayı seç">
                                        Seç &amp; Rezerve Et
                                    </a>
                                </div>
                            </article>
                        </div>
                        roomIdx++;
                    }
                </div>
            </div>
        </section>
    }

    <!-- ═══════════════════════════════════════════════════════════════
     GALLERY
════════════════════════════════════════════════════════════════ -->
    @{
        var galleryPhotos = new List<string>();
        if (hasRooms)
        {
            foreach (var r in Model.rooms.Values)
            {
                if (r?.photos == null) continue;
                foreach (var p in r.photos)
                {
                    if (!string.IsNullOrEmpty(p?.url_max300))
                        galleryPhotos.Add(p.url_max300);
                }
            }
        }
    }
    @if (galleryPhotos.Any())
    {
        <section class="gallery-section" id="gallery" aria-label="Fotoğraf galerisi">
            <div class="container-xl">
                <div class="fade-up mb-5">
                    <div class="section-label">Galeri</div>
                    <h2 class="section-title">Oda <em>Fotoğrafları</em></h2>
                    <div class="section-divider"></div>
                </div>

                <div class="bento-grid" id="bentoGrid">
                    @for (int gi = 0; gi < Math.Min(galleryPhotos.Count, 6); gi++)
                    {
                        <div class="bento-item"
                             data-index="@gi"
                             onclick="openLightbox(@gi)"
                             role="button"
                             tabindex="0"
                             aria-label="Fotoğraf @(gi + 1)">
                            <img src="@galleryPhotos[gi]"
                                 alt="Otel fotoğrafı @(gi + 1)"
                                 loading="lazy"
                                 onerror="this.closest('.bento-item').style.display='none'" />
                            <span class="expand-icon" aria-hidden="true">
                                <i class="bi bi-arrows-fullscreen"></i>
                            </span>
                        </div>
                    }
                </div>
            </div>

            <!-- Lightbox -->
            <div class="lightbox-overlay" id="lightboxOverlay" role="dialog" aria-modal="true" aria-label="Fotoğraf görüntüleyici">
                <button class="lightbox-close" onclick="closeLightbox()" aria-label="Kapat">
                    <i class="bi bi-x-lg"></i>
                </button>
                <button class="lightbox-prev" onclick="lightboxNav(-1)" aria-label="Önceki">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <img class="lightbox-img" id="lightboxImg" src="" alt="Otel fotoğrafı" />
                <button class="lightbox-next" onclick="lightboxNav(1)" aria-label="Sonraki">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </section>

        <script>
                var galleryUrls = [@Html.Raw(string.Join(",", galleryPhotos.Select(u => $"'{u}'")))];
                var lightboxIdx = 0;
                function openLightbox(idx) {
                    lightboxIdx = idx;
                    document.getElementById('lightboxImg').src = galleryUrls[idx];
                    document.getElementById('lightboxOverlay').classList.add('open');
                    document.body.style.overflow = 'hidden';
                }
                function closeLightbox() {
                    document.getElementById('lightboxOverlay').classList.remove('open');
                    document.body.style.overflow = '';
                }
                function lightboxNav(dir) {
                    lightboxIdx = (lightboxIdx + dir + galleryUrls.length) % galleryUrls.length;
                    document.getElementById('lightboxImg').src = galleryUrls[lightboxIdx];
                }
                document.getElementById('lightboxOverlay').addEventListener('click', function(e) {
                    if (e.target === this) closeLightbox();
                });
                document.addEventListener('keydown', function(e) {
                    if (!document.getElementById('lightboxOverlay').classList.contains('open')) return;
                    if (e.key === 'Escape') closeLightbox();
                    if (e.key === 'ArrowLeft') lightboxNav(-1);
                    if (e.key === 'ArrowRight') lightboxNav(1);
                });
        </script>
    }

    <!-- ═══════════════════════════════════════════════════════════════
     MAP
════════════════════════════════════════════════════════════════ -->
    @if (Model?.latitude != 0 || Model?.longitude != 0)
    {
        <section class="map-section" id="map" aria-label="Konum haritası">
            <div class="container-xl">
                <div class="fade-up mb-5">
                    <div class="section-label">Konum</div>
                    <h2 class="section-title">Mükemmel <em>Bir Adres</em></h2>
                    <div class="section-divider"></div>
                </div>
                <div class="map-wrapper fade-up">
                    <iframe src="https://www.openstreetmap.org/export/embed.html?bbox=@(Model.longitude - 0.02)%2C@(Model.latitude - 0.01)%2C@(Model.longitude + 0.02)%2C@(Model.latitude + 0.01)&layer=mapnik&marker=@Model.latitude%2C@Model.longitude"
                            allowfullscreen
                            loading="lazy"
                            title="Otel konumu haritası"
                            aria-label="@(Model?.hotel_name ?? "Otel") konumu"></iframe>
                    <div class="map-pin-card">
                        <div class="hotel-map-name">@(Model?.hotel_name ?? "Otel")</div>
                        <div class="hotel-map-addr">
                            <i class="bi bi-geo-alt-fill me-1" style="color:var(--primary)"></i>
                            @(Model?.hotel_address_line ?? Model?.address ?? $"{Model?.city}, {Model?.country_trans}")
                        </div>
                        @if (!string.IsNullOrEmpty(Model?.url))
                        {
                            <a href="@Model.url" target="_blank" rel="noopener noreferrer"
                               style="font-size:.68rem;color:var(--primary);text-decoration:none;display:inline-flex;align-items:center;gap:.3rem;margin-top:.5rem;">
                                <i class="bi bi-box-arrow-up-right"></i> Haritada aç
                            </a>
                        }
                    </div>
                </div>
            </div>
        </section>
    }

    <!-- ═══════════════════════════════════════════════════════════════
     POLICIES
════════════════════════════════════════════════════════════════ -->
    @{
        var activeBlock = Model?.block?.FirstOrDefault();
    }

    <section class="policies-section" id="policies" aria-label="Otel politikaları">
        <div class="container-xl">
            <div class="fade-up mb-5">
                <div class="section-label">Politikalar & Koşullar</div>
                <h2 class="section-title">Şeffaf <em>Bilgilendirme</em></h2>
                <div class="section-divider"></div>
            </div>

            <div class="row g-4">

                <!-- 1. CARD: Güvenli Rezervasyon (STATIC) -->
                <div class="col-md-4 fade-up">
                    <div class="policy-card">
                        <div class="policy-icon">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h3 class="policy-title">Güvenli Rezervasyon</h3>
                        <p class="policy-text">
                            Tüm ödemeleriniz SSL şifreli güvenli altyapı üzerinden gerçekleştirilmektedir.
                        </p>
                        <span class="policy-badge green">
                            <i class="bi bi-lock-fill me-1"></i>Güvenli
                        </span>
                    </div>
                </div>

                <!-- 2. CARD: İptal Politikası (DYNAMIC) -->
                <div class="col-md-4 fade-up fade-up-d1">
                    <div class="policy-card">
                        <div class="policy-icon">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </div>

                        <h3 class="policy-title">İptal Politikası</h3>

                        @if (activeBlock?.paymentterms?.cancellation != null)
                        {
                            <p class="policy-text">
                                @activeBlock.paymentterms.cancellation.description
                            </p>

                            <span class="policy-badge">
                                <i class="bi bi-info-circle me-1"></i>
                                @activeBlock.paymentterms.cancellation.type_translation
                            </span>
                        }
                        else
                        {
                            <p class="policy-text">
                                İptal koşulları seçilen oda ve tarihe göre değişiklik göstermektedir.
                            </p>
                        }
                    </div>
                </div>

                <!-- 3. CARD: Ödeme Koşulları (DYNAMIC) -->
                <div class="col-md-4 fade-up fade-up-d2">
                    <div class="policy-card">
                        <div class="policy-icon">
                            <i class="bi bi-credit-card"></i>
                        </div>

                        <h3 class="policy-title">Ödeme Koşulları</h3>

                        @if (activeBlock?.paymentterms?.prepayment != null)
                        {
                            <p class="policy-text">
                                @activeBlock.paymentterms.prepayment.description
                            </p>

                            <span class="policy-badge green">
                                <i class="bi bi-check-circle me-1"></i>
                                @activeBlock.paymentterms.prepayment.simple_translation
                            </span>
                        }
                        else if (Model?.composite_price_breakdown?.all_inclusive_amount != null)
                        {
                            <p class="policy-text">
                                Her şey dahil fiyatlandırma mevcuttur. Ekstra ücret olmadan konaklamanızın keyfini çıkarın.
                            </p>

                            <span class="policy-badge green">
                                <i class="bi bi-check-circle me-1"></i>Her şey dahil
                            </span>
                        }
                        else
                        {
                            <p class="policy-text">
                                Ödeme koşulları seçilen oda tipine ve tarihe göre belirlenmektedir.
                            </p>

                            <span class="policy-badge">
                                <i class="bi bi-calendar-check me-1"></i>Tarihe bağlı
                            </span>
                        }
                    </div>
                </div>

            </div>

            <!-- Bottom CTA -->
            <div class="text-center mt-5 fade-up">
                <p style="font-size:.8rem;color:var(--text-light);margin-bottom:1.5rem;">
                    Sorularınız için 7/24 müşteri desteğimizle iletişime geçebilirsiniz.
                </p>
                <a href="#booking-form" class="btn-hero-book"
                   style="display:inline-flex;"
                   aria-label="Rezervasyon yap">
                    <i class="bi bi-calendar-check"></i> Hemen Rezervasyon Yap
                </a>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════════════
     FOOTER
════════════════════════════════════════════════════════════════ -->
    <footer class="luxury-footer mt-5">
        <div class="container-xl">
            <div class="row g-4 mb-4">
                <div class="col-md-4">
                    <a class="footer-brand" href="/">
                        <span class="brand-icon">✦</span> LUXURY
                    </a>
                    <p class="footer-tagline">
                        Dünyanın En Prestijli<br>Otellerinde Deneyim
                    </p>
                </div>
                <div class="col-md-4">
                    <div class="footer-heading">Keşfet</div>
                    <a class="footer-link" href="/Luxury/Index#market-data">Canlı Veriler</a>
                    <a class="footer-link" href="/Luxury/Index#features">Özellikler</a>
                    <a class="footer-link" href="/Luxury/Index#destinations">Lokasyonlar</a>
                </div>
                <div class="col-md-4">
                    <div class="footer-heading">Bu Otel</div>
                    @if (!string.IsNullOrEmpty(Model?.hotel_name))
                    {
                        <p style="font-size:.76rem;color:rgba(255,255,255,.5);line-height:1.7;">
                            <strong style="color:rgba(255,255,255,.75);">@Model.hotel_name</strong><br />
                            @(Model?.hotel_address_line ?? Model?.address ?? $"{Model?.city}, {Model?.country_trans}")
                        </p>
                    }
                    @if (!string.IsNullOrEmpty(Model?.url))
                    {
                        <a href="@Model.url" target="_blank" rel="noopener noreferrer" class="footer-link" style="margin-top:.5rem;display:inline-flex;align-items:center;gap:.3rem;">
                            <i class="bi bi-box-arrow-up-right"></i> Otel websitesi
                        </a>
                    }
                </div>
            </div>
            <hr class="footer-divider" />
            <div class="footer-bottom">
                <span>© @DateTime.Now.Year LUXURY. Tüm hakları saklıdır.</span>
                <div style="display:flex;gap:1.5rem;">
                    <a href="#">Gizlilik</a>
                    <a href="#">Kullanım Koşulları</a>
                    <a href="#">Çerezler</a>
                </div>
            </div>
        </div>
    </footer>

    <button class="back-to-top" id="backToTop" aria-label="Sayfa başına dön"></button>

    <!-- ═══════════════════════════════════════════════════════════════
     SCRIPTS
════════════════════════════════════════════════════════════════ -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/hoteldetails.js"></script>
</body>
</html>
