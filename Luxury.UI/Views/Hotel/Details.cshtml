@model HotelDetailDto

@{
    ViewData["Title"] = Model.HotelName;
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.HotelName — LUXURY</title>
    <meta name="description" content="@(Model.Description != null ? (Model.Description.Length > 160 ? Model.Description.Substring(0, 160) + "..." : Model.Description) : Model.HotelName + " - Luxury Hotel")" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="~/css/hoteldetails.css" rel="stylesheet" />
</head>
<body>

    <nav class="navbar navbar-expand-lg luxury-nav" id="mainNav" role="navigation" aria-label="Main navigation">
        <div class="container-xl">
            <a class="navbar-brand luxury-brand" href="/" aria-label="Luxury — Ana Sayfa">
                <span class="brand-icon" aria-hidden="true">✦</span>
                <span class="brand-text">LUXURY</span>
            </a>
            <button class="navbar-toggler border-0 p-0 luxury-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarContent"
                    aria-controls="navbarContent" aria-expanded="false" aria-label="Menüyü aç/kapat">
                <span></span><span></span><span></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav mx-auto gap-lg-4">
                    <li class="nav-item"><a class="nav-link luxury-nav-link" href="/Luxury/Index#market-data">Canlı Veriler</a></li>
                    <li class="nav-item"><a class="nav-link luxury-nav-link" href="/Luxury/Index#features">Özellikler</a></li>
                    <li class="nav-item"><a class="nav-link luxury-nav-link" href="/Luxury/Index#destinations">Lokasyonlar</a></li>
                </ul>
                <div class="nav-actions d-flex align-items-center gap-3">
                    <a href="#booking-form" class="btn-primary-nav" aria-label="Rezervasyon Yap">Rezervasyon Yap</a>
                </div>
            </div>
        </div>
    </nav>

    <section class="hero-section" aria-label="Otel bilgileri">
        <div class="hero-bg-gallery" id="heroBg" aria-hidden="true">
            @if (Model.GalleryPhotos != null && Model.GalleryPhotos.Any())
            {
                int heroIdx = 0;
                foreach (var photo in Model.GalleryPhotos.Take(6))
                {
                    <img src="@photo.Url" alt=""
                         class="@(heroIdx == 0 ? "active" : "")"
                         loading="@(heroIdx == 0 ? "eager" : "lazy")" />
                    heroIdx++;
                }
            }
        </div>

        <div class="hero-overlay" aria-hidden="true"></div>

        <div class="hero-content">
            <div class="container-xl">
                <div class="row">
                    <div class="col-lg-8">

                        @if (!string.IsNullOrWhiteSpace(Model.AccommodationTypeName))
                        {
                            <div class="hero-badge">
                                <i class="bi bi-gem" aria-hidden="true"></i>
                                @Model.AccommodationTypeName
                            </div>
                        }

                        <h1 class="hero-title">@Model.HotelName</h1>

                        @if (!string.IsNullOrWhiteSpace(Model.City) || !string.IsNullOrWhiteSpace(Model.CountryTrans))
                        {
                            <p class="hero-location">
                                <i class="bi bi-geo-alt-fill" aria-hidden="true"></i>
                                <span>
                                    @Model.City@(!string.IsNullOrWhiteSpace(Model.City) && !string.IsNullOrWhiteSpace(Model.CountryTrans) ? ", " : "")@Model.CountryTrans
                                </span>
                            </p>
                        }

                        @if (!string.IsNullOrWhiteSpace(Model.Address))
                        {
                            <p class="hero-address">
                                <i class="bi bi-map me-1" aria-hidden="true"></i>
                                @Model.Address
                            </p>
                        }

                        <div class="hero-meta-row">
                            @if (Model.DistanceToCenter > 0)
                            {
                                <span class="hero-meta-chip">
                                    <i class="bi bi-building" aria-hidden="true"></i>
                                    Merkeze @Model.DistanceToCenter.ToString("0.0") km
                                </span>
                            }
                            @if (Model.ReviewCount > 0)
                            {
                                <span class="hero-meta-chip">
                                    <i class="bi bi-star-fill" aria-hidden="true"></i>
                                    @Model.ReviewCount.ToString("N0") Değerlendirme
                                </span>
                            }
                            @if (Model.AvailableRooms > 0)
                            {
                                <span class="hero-meta-chip">
                                    <i class="bi bi-door-open" aria-hidden="true"></i>
                                    @Model.AvailableRooms Oda Mevcut
                                </span>
                            }
                            @if (Model.IsFamilyFriendly)
                            {
                                <span class="hero-meta-chip">
                                    <i class="bi bi-people-fill" aria-hidden="true"></i>
                                    Aile Dostu
                                </span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.PrepaymentText) || !string.IsNullOrWhiteSpace(Model.CancellationType))
                        {
                            <div class="hero-meta-row mt-2 border-top border-white-10 pt-2" style="gap: 10px;">
                                @if (!string.IsNullOrWhiteSpace(Model.PrepaymentText))
                                {
                                    <span class="badge bg-success bg-opacity-20 text-success border border-success border-opacity-30 px-3 py-2 rounded-pill small d-inline-flex align-items-center" style="font-family: var(--font-sans); font-weight: 500; letter-spacing: 0.3px;">
                                        <i class="bi bi-credit-card-off me-2"></i> @Model.PrepaymentText
                                    </span>
                                }
                                @if (!string.IsNullOrWhiteSpace(Model.CancellationType))
                                {
                                    <span class="badge bg-info bg-opacity-20 text-info border border-info border-opacity-30 px-3 py-2 rounded-pill small d-inline-flex align-items-center" style="font-family: var(--font-sans); font-weight: 500; letter-spacing: 0.3px;">
                                        <i class="bi bi-arrow-counterclockwise me-2"></i> @Model.CancellationType
                                    </span>
                                }
                            </div>
                        }

                        <div class="hero-scroll-hint" aria-hidden="true">
                            <span class="scroll-line"></span>
                            <span>Keşfetmek için kaydırın</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @{
        var allPhotos = new List<Luxury.DtoLayer.Dtos.HotelSearchDtos.HotelPhotoDto>();
        if (Model.RoomPhotos != null) allPhotos.AddRange(Model.RoomPhotos);
    }

    @if (allPhotos.Any())
    {
        <section id="gallery" aria-label="Fotoğraf galerisi">
            <div class="container-xl">
                <div class="row mb-5">
                    <div class="col-12">
                        <p class="section-label">Galeri</p>
                        <h2 class="section-title">Oteli Keşfedin</h2>
                        <div class="divider-gold"></div>
                    </div>
                </div>

                <div class="gallery-bento-wrapper">
                    <div class="gallery-main-container">
                        <img id="galleryMain"
                             src="@allPhotos[0].Url"
                             alt="@Model.HotelName fotoğrafı"
                             class="gallery-main-img"
                             loading="lazy" />
                    </div>

                    <div class="gallery-thumbs-grid" id="galleryThumbs" role="list">
                        @for (int i = 0; i < allPhotos.Count && i < 20; i++)
                        {
                            <img src="@allPhotos[i].Url"
                                 alt="@Model.HotelName fotoğraf @(i + 1)"
                                 class="gallery-thumb @(i == 0 ? "active" : "") @(i >= 5 ? "d-none" : "")"
                                 data-index="@i"
                                 loading="lazy"
                                 role="listitem"
                                 tabindex="0"
                                 aria-label="Fotoğraf @(i + 1) - görüntüle" />
                        }
                    </div>
                </div>

                <div class="row">
                    <div class="col-12 text-end">
                        <p class="gallery-counter" aria-live="polite">
                            <span id="currentPhotoNum">1</span> / @(Math.Min(allPhotos.Count, 20)) fotoğraf
                        </p>
                    </div>
                </div>
            </div>
        </section>
    }

    <section id="booking-form" aria-label="Fiyat ve rezervasyon">
        <div class="container-xl">
            <div class="row g-5 align-items-start">

                <div class="col-lg-7">
                    <p class="section-label">Otel Bilgisi</p>
                    <h2 class="section-title">@Model.HotelName</h2>
                    <div class="divider-gold"></div>

                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <p class="description-text">@Model.Description</p>
                    }

                    @if (Model.SpokenLanguages != null && Model.SpokenLanguages.Any())
                    {
                        <div class="mt-4">
                            <p class="section-label" style="margin-bottom: 14px;">Konuşulan Diller</p>
                            <div class="tag-cloud">
                                @foreach (var lang in Model.SpokenLanguages)
                                {
                                    <span class="tag-item">
                                        <i class="bi bi-translate me-1" aria-hidden="true"></i>
                                        @lang
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="col-lg-5">
                    <div class="price-card" role="complementary" aria-label="Fiyat bilgisi">

                        <div id="panel-original">
                            <p class="section-label" style="margin-bottom: 8px;">Gecelik Ücret</p>
                            <div class="d-flex align-items-baseline gap-1">
                                @if (!string.IsNullOrWhiteSpace(Model.Currency))
                                {
                                    <span class="price-per-night currency-sym" aria-hidden="true">@Model.Currency</span>
                                }
                                <span class="price-per-night"
                                      aria-label="Gecelik fiyat @Model.GrossAmountPerNight @Model.Currency">
                                    @Model.GrossAmountPerNight
                                </span>
                            </div>
                            <p class="price-label">gecelik</p>

                            @if (!string.IsNullOrWhiteSpace(Model.GrossAmount) && Model.GrossAmount != "0")
                            {
                                <div class="price-total-row d-flex justify-content-between align-items-center flex-wrap gap-1">
                                    <div>
                                        <div class="price-total-label">Toplam Tutar</div>
                                    </div>
                                    <span class="price-total-value">
                                        @if (!string.IsNullOrWhiteSpace(Model.Currency))
                                        {
                                            @Model.Currency
                                        }
                                        @Model.GrossAmount
                                    </span>
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Model.HighlightedBenefit))
                        {
                            <div class="p-3 my-3 rounded-3 d-flex align-items-start border border-primary border-opacity-20" style="background-color: rgba(212, 175, 55, 0.05); border-left: 4px solid var(--color-primary) !important;">
                                <i class="bi bi-gift text-primary fs-5 me-3 mt-0.5"></i>
                                <div>
                                    <span class="d-block fw-bold text-light small uppercase tracking-wider mb-0.5" style="letter-spacing: 0.5px; font-size: 0.8rem;">Bu Seçeneğe Özel Avantaj</span>
                                    <span style="color: var(--color-text-muted); font-size: 0.85rem;">@Model.HighlightedBenefit</span>
                                </div>
                            </div>
                        }

                        @if (Model.AvailableRooms > 0)
                        {
                            <div>
                                <span class="availability-badge @(Model.AvailableRooms <= 3 ? "limited" : "available")">
                                    <span class="dot" aria-hidden="true"></span>
                                    @if (Model.AvailableRooms <= 3)
                                    {
                                        <span>Son @Model.AvailableRooms oda kaldı!</span>
                                    }
                                    else
                                    {
                                        <span>@Model.AvailableRooms oda mevcut</span>
                                    }
                                </span>
                            </div>
                        }

                        <button class="btn-book-now" type="button" aria-label="Rezervasyon yap">
                            <i class="bi bi-calendar-check me-2" aria-hidden="true"></i>
                            Rezervasyon Yap
                        </button>

                        @if (!string.IsNullOrWhiteSpace(Model.Timezone))
                        {
                            <p class="text-center mt-3" style="font-size: 0.75rem; color: var(--color-text-light);">
                                <i class="bi bi-clock me-1" aria-hidden="true"></i>
                                Yerel Saat Dilimi: @Model.Timezone
                            </p>
                        }
                    </div>
                </div>

            </div>
        </div>
    </section>

    <section id="info" aria-label="İstatistikler ve metrikler">
        <div class="container-xl">
            <div class="row mb-5">
                <div class="col-12">
                    <p class="section-label">Genel Bakış</p>
                    <h2 class="section-title">Rakamlarla @Model.HotelName</h2>
                    <div class="divider-gold"></div>
                </div>
            </div>
            <div class="row g-4">
                @if (Model.ReviewCount > 0)
                {
                    <div class="col-6 col-md-3">
                        <div class="metric-card">
                            <div class="metric-value" aria-label="@Model.ReviewCount değerlendirme">@Model.ReviewCount.ToString("N0")</div>
                            <div class="review-stars" aria-hidden="true">★★★★★</div>
                            <div class="metric-label">Değerlendirme</div>
                        </div>
                    </div>
                }
                @if (Model.AvailableRooms > 0)
                {
                    <div class="col-6 col-md-3">
                        <div class="metric-card">
                            <div class="metric-value" aria-label="@Model.AvailableRooms mevcut oda">@Model.AvailableRooms</div>
                            <div class="metric-label">Mevcut Oda</div>
                        </div>
                    </div>
                }
                @if (Model.DistanceToCenter > 0)
                {
                    <div class="col-6 col-md-3">
                        <div class="metric-card">
                            <div class="metric-value" aria-label="Merkeze @Model.DistanceToCenter.ToString("0.0") km">@Model.DistanceToCenter.ToString("0.0")</div>
                            <div class="metric-label">km — Merkeze Uzaklık</div>
                        </div>
                    </div>
                }
                @if (Model.Facilities != null && Model.Facilities.Any())
                {
                    <div class="col-6 col-md-3">
                        <div class="metric-card">
                            <div class="metric-value" aria-label="@Model.Facilities.Count tesis">@Model.Facilities.Count</div>
                            <div class="metric-label">Tesis &amp; Olanak</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <section id="features" aria-label="Tesisler ve özellikler">
        <div class="container-xl">

            @if (Model.Facilities != null && Model.Facilities.Any())
            {
                <div class="row mb-5">
                    <div class="col-12">
                        <p class="section-label">Olanaklar</p>
                        <h2 class="section-title">Tesisler &amp; Hizmetler</h2>
                        <div class="divider-gold"></div>
                    </div>
                </div>
                <div class="facility-grid" role="list">
                    @foreach (var facility in Model.Facilities)
                    {
                        <div class="facility-item" role="listitem">
                            <div class="facility-icon" aria-hidden="true">
                                @if (!string.IsNullOrWhiteSpace(facility.Icon))
                                {
                                    <i class="bi bi-@facility.Icon"></i>
                                }
                                else
                                {
                                    <i class="bi bi-check2-circle"></i>
                                }
                            </div>
                            <span class="facility-name">@facility.Name</span>
                        </div>
                    }
                </div>
            }

            @if (Model.TopBenefits != null && Model.TopBenefits.Any())
            {
                <div class="row mt-5 mb-4">
                    <div class="col-12">
                        <p class="section-label">Avantajlar</p>
                        <h3 class="section-title" style="font-size: clamp(1.4rem, 2.5vw, 2rem);">Öne Çıkan Faydalar</h3>
                        <div class="divider-gold"></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-8">
                        <ul class="benefits-list" role="list">
                            @foreach (var benefit in Model.TopBenefits)
                            {
                                <li class="benefit-item" role="listitem">
                                    <span class="benefit-dot" aria-hidden="true"></span>
                                    @benefit
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            }

            @if (Model.IsFamilyFriendly && Model.FamilyFacilities != null && Model.FamilyFacilities.Any())
            {
                <div class="family-section" role="region" aria-label="Aile dostu tesisler">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="facility-icon" style="width: 48px; height: 48px; font-size: 1.3rem;" aria-hidden="true">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div>
                            <p class="section-label mb-1">Aile Dostu</p>
                            <h3 style="font-family: var(--font-display); font-size: 1.5rem; color: var(--color-accent); margin: 0;">Aile Olanakları</h3>
                        </div>
                    </div>
                    <div class="tag-cloud" role="list">
                        @foreach (var fac in Model.FamilyFacilities)
                        {
                            <span class="tag-item" role="listitem">
                                <i class="bi bi-check-circle me-1" style="color: var(--color-primary);" aria-hidden="true"></i>
                                @fac
                            </span>
                        }
                    </div>
                </div>
            }

        </div>
    </section>

    @if (Model.Latitude != 0 && Model.Longitude != 0)
    {
        <section id="map-section" aria-label="Konum haritası">
            <div class="container-xl">
                <div class="row mb-5">
                    <div class="col-12">
                        <p class="section-label">Konum</p>
                        <h2 class="section-title">Bizi Haritada Bulun</h2>
                        <div class="divider-gold"></div>
                    </div>
                </div>
                <div class="map-wrapper">
                    <iframe title="@Model.HotelName konumu"
                            src="https://www.openstreetmap.org/export/embed.html?bbox=@(Model.Longitude - 0.01)%2C@(Model.Latitude - 0.01)%2C@(Model.Longitude + 0.01)%2C@(Model.Latitude + 0.01)&layer=mapnik&marker=@Model.Latitude%2C@Model.Longitude"
                            loading="lazy"
                            aria-label="@Model.HotelName harita görünümü">
                    </iframe>
                </div>
                <p class="mt-3" style="font-size: 0.8rem; color: var(--color-text-muted);">
                    <i class="bi bi-geo-alt me-1" aria-hidden="true"></i>
                    Koordinatlar: @Model.Latitude.ToString("0.000000"), @Model.Longitude.ToString("0.000000")
                </p>
            </div>
        </section>
    }

    @if (!string.IsNullOrWhiteSpace(Model.CancellationDescription))
    {
        <section id="policy" aria-label="İptal politikası">
            <div class="container-xl">
                <div class="row mb-5">
                    <div class="col-12">
                        <p class="section-label">Politika</p>
                        <h2 class="section-title">İptal &amp; Koşullar</h2>
                        <div class="divider-gold"></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-lg-8">
                        <div class="policy-card" role="note" aria-label="İptal politikası detayları">
                            <div class="policy-icon" aria-hidden="true">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <p class="policy-text">@Model.CancellationDescription</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }

    <footer class="luxury-footer mt-5" role="contentinfo">
        <div class="container-xl">
            <div class="footer-top py-5">
                <div class="row g-5">
                    <div class="col-12 col-lg-8">
                        <div class="footer-brand mb-3 font-playfair fs-3" style="letter-spacing: 3px;">
                            <span class="brand-icon">✦</span>
                            <span class="brand-text">LUXURY</span>
                        </div>
                        <p class="footer-desc text-white-50 w-75">Dünyanın en seçkin otellerini tek platformda modern, minimalist ve fütüristik bir arayüz deneyimiyle keşfedin.</p>
                        <div class="footer-social d-flex gap-3 mt-4">
                            <a href="#" class="social-link" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                            <a href="#" class="social-link" aria-label="Twitter/X"><i class="bi bi-twitter-x"></i></a>
                            <a href="#" class="social-link" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-4 text-lg-end">
                        <h4 class="footer-col-title text-white mb-3 font-playfair">Platform</h4>
                        <ul class="footer-links list-unstyled d-flex flex-column gap-2">
                            <li><a href="/Luxury/Index#market-data">Canlı Veriler</a></li>
                            <li><a href="/Luxury/Index#features">Gizlilik Politikası</a></li>
                            <li><a href="/Luxury/Index#destinations">Kullanım Şartları</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="footer-bottom py-3 text-center">
                <p class="footer-copy text-white-50 small mb-0">© @DateTime.Now.Year Luxury. Tüm hakları saklıdır.</p>
            </div>
        </div>
    </footer>

    <button class="back-to-top" id="backToTop" aria-label="Sayfanın başına git">
        <i class="bi bi-chevron-up"></i>
    </button>
</body>
</html>