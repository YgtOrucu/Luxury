@model List<ResultHotelDto>
@{
    Layout = null;
    var firstHotel = Model?.FirstOrDefault() ?? new ResultHotelDto();
    var currentCity = firstHotel?.WishlistName ?? "Dubai";
}

<!DOCTYPE html>
<html lang="tr">
@await Component.InvokeAsync("LuxuryHotelListHead", new { currentCity = currentCity })
<body>

    <div class="grain-overlay" aria-hidden="true"></div>

    <div class="container py-4">
        @await Component.InvokeAsync("LuxuryHotelListNavbar")
        @await Component.InvokeAsync("LuxuryHotelListBooking", new { firstHotel = firstHotel, adults = ViewBag.Adults, rooms = ViewBag.Rooms, children = ViewBag.Children })
        @await Component.InvokeAsync("LuxuryHotelListSkeletonContainer", new { firstHotel = firstHotel, ModelCount = Model?.Count })
        @await Component.InvokeAsync("LuxuryHotelListAllHotels", new { AllHotel = Model })
    </div>

    @await Component.InvokeAsync("LuxuryHotelListFooter")

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/hotelpage.js"></script>

</body>
</html>